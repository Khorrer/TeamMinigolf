# Django
DJANGO_SECRET_KEY=change-me-to-a-random-string-at-least-50-chars
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# For local dev without MariaDB: DATABASE_ENGINE=django.db.backends.sqlite3
# DATABASE_ENGINE=django.db.backends.sqlite3

# MariaDB
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=minigolf
MYSQL_USER=minigolf
MYSQL_PASSWORD=change-me-user

# Backup (Push to remote via rsync)
BACKUP_REMOTE_HOST=192.168.1.100
BACKUP_REMOTE_USER=pi
BACKUP_REMOTE_PATH=/home/pi/backups/minigolf
BACKUP_RETAIN_DAYS=30

# Cloudflare Tunnel (optional, fill in when ready)
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here
